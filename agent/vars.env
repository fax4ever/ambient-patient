# API Keys
NVIDIA_API_KEY="nvapi-" 
NGC_API_KEY=""
TAVILY_API_KEY="tvly-"

# Main Agent LLM
AGENT_LLM_BASE_URL="https://integrate.api.nvidia.com/v1"
AGENT_LLM_MODEL="meta/llama-3.3-70b-instruct"

# Main Agent LLM if self hosted LLM:
#AGENT_LLM_BASE_URL="http://agent-instruct-llm:8000/v1"
#AGENT_LLM_MODEL="meta/llama-3.3-70b-instruct"

# Logging Level for the Agent
LOG_LEVEL=INFO

# Nemo Guardrails Config Path, leave empty to disable
NEMO_GUARDRAILS_CONFIG_PATH=nmgr-config-store/patient-intake-nemoguard

# Optional Config for Langsmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=healthcare-agent-project
LANGSMITH_API_KEY=your-api-key

# Agent App Configs
TIMEZONE="America/Los_Angeles"
APP_OUTPUT_DIR="app_output_files"
