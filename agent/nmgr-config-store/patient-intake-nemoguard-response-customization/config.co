
define bot refuse to respond
  "I'm afraid I won't be able to answer that."

define bot refuse to respond for pii
  "I'm afraid I won't be able to answer that for privacy reasons."

define bot refuse to respond for medical advice or diagnosis
  "I'm afraid I won't be able to give medical advice or diagnosis."

define flow content safety check input
  $response = execute content_safety_check_input

  $allowed = $response["allowed"]
  # Policy violations are currently unused, but can be used to better phrase the bot output
  $policy_violations = $response["policy_violations"]

  if not $allowed
    if $config.enable_rails_exceptions
      create event ContentSafetyCheckInputException(message="Input not allowed. The input was blocked by the 'content safety check input $model='{$model}'' flow.")
    else
      $has_pii = execute check_policy_for_keyword(policy_violations=$policy_violations, keyword="PII")
      $medical_advice = execute check_policy_for_keyword(policy_violations=$policy_violations, keyword="medical advice")
      $medical_diagnosis = execute check_policy_for_keyword(policy_violations=$policy_violations, keyword="medical diagnosis")
      if $has_pii
        bot refuse to respond for pii
      else
        if $medical_advice or $medical_diagnosis
          bot refuse to respond for medical advice or diagnosis
        else
          bot refuse to respond
    stop

define flow content safety check output
  $response = execute content_safety_check_output
  $allowed = $response["allowed"]
  $policy_violations = $response["policy_violations"]

  if not $allowed
    if $config.enable_rails_exceptions
      create event ContentSafetyCheckOuputException(message="Output not allowed. The output was blocked by the 'content safety check output $model='{$model}'' flow.")
    else
      bot refuse to respond
    stop